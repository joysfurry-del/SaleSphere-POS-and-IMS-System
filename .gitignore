# Ignore other projects inside htdocs
/*
!/.gitignore
!/salesphere/
!/commerce/

# Environment and secret files
.env
.env.*
!.env.example

# Generated PDF files
/salesphere/test_output.pdf
/salesphere/test_sales_report.pdf

# Temporary testing files
/salesphere/test_pdf.php
/salesphere/validate_pdf.php

# Runtime profile uploads
/salesphere/public/assets/uploads/profiles/*

# Logs and operating-system files
*.log
Thumbs.db
.DS_Store